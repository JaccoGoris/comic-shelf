# ── Database ─────────────────────────────────────────────
POSTGRES_USER=comic_shelf
POSTGRES_PASSWORD=comic_shelf
POSTGRES_DB=comic_shelf
# In dev, the DB runs on localhost. In Docker it's the service name "postgres".
POSTGRES_HOST=localhost

# ── App ──────────────────────────────────────────────────
PORT=3000
DB_PORT=5432

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION=7d

# ── Metron API (optional) ────────────────────────────────
METRON_USERNAME=
METRON_PASSWORD=
METRON_API_BASE_URL=https://metron.cloud
